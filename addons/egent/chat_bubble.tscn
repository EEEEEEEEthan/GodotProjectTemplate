[sub_resource type="GDScript" id="GDScript_ykpk4"]
script/source = "@tool
extends Container

@export var text: String:
	set(value):
		text = value
		if not is_node_ready():
			await ready
		%RichTextLabel.text = value

func _get_maximum_size() -> Vector2:
	var font := get_theme_font(&\"normal_font\")
	var font_size := get_theme_font_size(&\"normal_font_size\")
	var text_width := font.get_string_size(
		%RichTextLabel.get_parsed_text(),  # 纯文本，去掉 BBCode
		%RichTextLabel.horizontal_alignment,
		-1,  # 不限制宽度
		font_size
	).x
	var panel_insets = get_theme_stylebox(&\"panel\").get_minimum_size()
	return Vector2(text_width + panel_insets.x, 9999999)
"

